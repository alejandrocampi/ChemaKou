<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/title_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué quieres saber?"
            android:textSize="28sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"/>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/circle_white_blue_border"/>

            <ImageView
                android:id="@+id/btn_microphone"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/ic_voice"
                android:layout_gravity="center"/>

        </FrameLayout>

        <TextView
            android:id="@+id/txt_pulsa_habla"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pulsa y habla"
            android:textSize="18sp"
            android:textColor="#757575"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/txt_listening_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#F44336"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/txt_last_command_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Último comando:"
            android:textSize="18sp"
            android:textColor="#2196F3"
            android:textStyle="bold"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_last_command"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_response"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#424242"
                    android:padding="16dp"
                    android:background="@drawable/border_blue_rounded"
                    android:visibility="gone"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp">

                    <LinearLayout
                        android:id="@+id/last_command_content"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/last_command_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="16dp"/>

                        <TextView
                            android:id="@+id/last_command_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="18sp"
                            android:textColor="#424242"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txt_no_last_command"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Aún no has ejecutado ningún comando"
                        android:textSize="16sp"
                        android:textColor="#9E9E9E"
                        android:gravity="center"
                        android:padding="16dp"/>

                </FrameLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_text_reader"
                android:layout_width="140dp"
                android:layout_height="120dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/border_blue_rounded"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:src="@drawable/ic_camera"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LECTOR DE TEXTO"
                        android:textSize="14sp"
                        android:textColor="#1976D2"
                        android:textStyle="bold"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_geolocation"
                android:layout_width="140dp"
                android:layout_height="120dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/border_blue_rounded"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:src="@drawable/ic_location"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GEOLOCALIZACIÓN"
                        android:textSize="14sp"
                        android:textColor="#1976D2"
                        android:textStyle="bold"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>